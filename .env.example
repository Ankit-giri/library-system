# ─────────────────────────────────────────────────────────
#  Library Management System — Environment Variables
#  Copy this file to .env and fill in your values.
#
#    cp .env.example .env
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# ── JWT ───────────────────────────────────────────────────
# Must be a Base64-encoded 256-bit (32-byte) secret.
# Generate a new one:
#   openssl rand -base64 32
JWT_SECRET=zQJ0ZpPt4mPZVYh0Zc1nOe2P0ySmx3Ee2TPu3C5g8KU=

# ── Frontend (Vite build-time variable) ──────────────────
# URL of the API gateway as seen from the browser.
# For local Docker: http://localhost:8080
# For remote deployment: https://api.your-domain.com
VITE_API_URL=http://localhost:8080
